# Copy to .env and fill in real values. Never commit .env.

# --- LLM providers (Ask panel; at minimum GITHUB_TOKEN for free dev tier) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GITHUB_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# --- Neo4j (local Docker or Aura) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# --- LangSmith (tracing + CI parsing eval) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
# Alias accepted by gcp_deploy.sh when syncing GCP secrets:
# LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=dubai-graph-sync-agent

# --- Frontend / API ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Optional: Google Cloud deploy ---
# GCP_PROJECT_ID=
# GCP_REGION=me-central1
# NEO4J_URI=neo4j+s://YOUR_AURA_ID.databases.neo4j.io

# --- Optional: override default config/model_pricing.yaml ---
# MODEL_PRICING_PATH=config/model_pricing.yaml

# --- Optional: sync token rates from LangSmith at API startup (needs LANGCHAIN_API_KEY) ---
# SYNC_LANGSMITH_PRICING=true
# SYNC_LANGSMITH_PRICING_WRITE=false
# LANGSMITH_PRICING_PROBES_PATH=config/langsmith_pricing_probes.yaml
